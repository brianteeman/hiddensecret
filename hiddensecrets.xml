<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="system" method="upgrade">
	<name>PLG_SYSTEM_HIDDENSECRETS</name>
	<author>Brian Teeman</author>
	<creationDate>July 2026</creationDate>
	<copyright>Copyright (c) 2026 Brian Teeman. All rights reserved.</copyright>
	<license>GNU General Public License version 2 or later; see LICENSE.txt</license>
	<authorEmail>brian@teeman.net</authorEmail>
	<authorUrl>https://brian.teeman.net</authorUrl>
	<version>1.0.0</version>
	<description>PLG_SYSTEM_HIDDENSECRETS_XML_DESCRIPTION</description>

	<namespace path="src">Brian\Plugin\System\HiddenSecrets</namespace>

	<files>
		<folder plugin="hiddensecrets">services</folder>
		<folder>src</folder>
		<folder>layouts</folder>
		<folder>language</folder>
	</files>

	<media destination="plg_system_hiddensecrets" folder="media">
		<folder>js</folder>
	</media>

	<languages>
		<language tag="en-GB">language/en-GB/plg_system_hiddensecrets.ini</language>
		<language tag="en-GB">language/en-GB/plg_system_hiddensecrets.sys.ini</language>
	</languages>

	<config>
		<fields name="params">

			<fieldset name="basic">

				<field name="selector"
					   type="text"
					   label="PLG_SYSTEM_HIDDENSECRETS_FIELD_SELECTOR_LABEL"
					   description="PLG_SYSTEM_HIDDENSECRETS_FIELD_SELECTOR_DESC"
					   default=".navbar-brand" />

				<field name="position"
					   type="text"
					   label="PLG_SYSTEM_HIDDENSECRETS_FIELD_POSITION_LABEL"
					   description="PLG_SYSTEM_HIDDENSECRETS_FIELD_POSITION_DESC"
					   default="hiddensecret" />

				<field name="title"
					   type="text"
					   label="PLG_SYSTEM_HIDDENSECRETS_FIELD_TITLE_LABEL"
					   description="PLG_SYSTEM_HIDDENSECRETS_FIELD_TITLE_DESC" />

				<field name="size"
					   type="list"
					   label="PLG_SYSTEM_HIDDENSECRETS_FIELD_SIZE_LABEL"
					   default="lg">

					<option value="sm">PLG_SYSTEM_HIDDENSECRETS_OPTION_SM</option>
					<option value="lg">PLG_SYSTEM_HIDDENSECRETS_OPTION_LG</option>
					<option value="xl">PLG_SYSTEM_HIDDENSECRETS_OPTION_XL</option>
					<option value="fullscreen">PLG_SYSTEM_HIDDENSECRETS_OPTION_FULLSCREEN</option>

				</field>

				<field name="backdrop" type="radio" layout="joomla.form.field.radio.switcher" filter="integer" default="1"
					   label="PLG_SYSTEM_HIDDENSECRETS_FIELD_BACKDROP_LABEL">
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>

				<field name="keyboard" type="radio" layout="joomla.form.field.radio.switcher" filter="integer" default="1"
					   label="PLG_SYSTEM_HIDDENSECRETS_FIELD_KEYBOARD_LABEL">
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>

				<field name="focus" type="radio" layout="joomla.form.field.radio.switcher" filter="integer" default="1"
					   label="PLG_SYSTEM_HIDDENSECRETS_FIELD_FOCUS_LABEL">
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>

				<field name="suppress_context"
					   type="radio"
					   layout="joomla.form.field.radio.switcher"
					   filter="integer"
					   default="1"
					   label="PLG_SYSTEM_HIDDENSECRETS_FIELD_SUPPRESS_CONTEXT_LABEL">
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>

				<field name="debug"
					   type="radio"
					   layout="joomla.form.field.radio.switcher"
					   filter="integer"
					   default="0"
					   label="PLG_SYSTEM_HIDDENSECRETS_FIELD_DEBUG_LABEL">
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>

			</fieldset>

		</fields>
	</config>
	<updateservers>
		<server type="extension" priority="1" name="HiddenSecrets Update Site">https://raw.githubusercontent.com/brianteeman/hiddensecret/main/manifest.xml</server>
	</updateservers>
</extension>